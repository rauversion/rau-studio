{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Aifficator",
  "version": "0.1.0",
  "identifier": "com.aifficator.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "security": {
      "assetProtocol": {
        "enable": true,
        "scope": ["$HOME/**", "/Volumes/**"]
      }
    },
    "windows": [
      {
        "title": "Aifficator",
        "width": 1280,
        "height": 820,
        "minWidth": 980,
        "minHeight": 640
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
